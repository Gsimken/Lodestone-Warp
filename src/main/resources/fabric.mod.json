{
	"schemaVersion": 1,
	"id": "lodestone_teleport",
	"version": "${version}",
	"name": "Lodestone Warps",
	"description": "Turn vanilla Lodestones into a configurable warp network with server-side validation, vanilla Dialog support, and an optional enhanced client UI.",
	"icon": "assets/lodestone_teleport/icon.png",
	"authors": [
		"GSimken"
	],
	"contact": {
		"homepage": "https://github.com/Gsimken/Lodestone-Warp",
		"sources": "https://github.com/Gsimken/Lodestone-Warp",
		"issues": "https://github.com/Gsimken/Lodestone-Warp/issues"
	},
	"license": "MIT",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.simke.lodestoneteleport.LodestoneTeleportMod"
		],
		"client": [
			"dev.simke.lodestoneteleport.client.LodestoneTeleportClient"
		],
		"modmenu": [
			"dev.simke.lodestoneteleport.client.LodestoneModMenuIntegration"
		]
	},
	"mixins": [
		"lodestone_teleport.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-permission-api-v1": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
